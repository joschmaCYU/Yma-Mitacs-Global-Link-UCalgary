<!-- ===== IMU link + joint ===== -->
  <link name="imu_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.01"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.011"/></geometry>
    </collision>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base"/>
    <child  link="imu_link"/>

    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>


</robot>

