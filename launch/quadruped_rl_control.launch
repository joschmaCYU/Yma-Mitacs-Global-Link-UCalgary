<launch>
  <!-- ========================================== -->
  <!-- 1. Launch Gazebo Simulation (Paused by default) -->
  <!-- ========================================== -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="paused" value="true"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="gui" value="true"/>
    <arg name="headless" value="false"/>
    <arg name="debug" value="false"/>
  </include>

  <!-- ========================================== -->
  <!-- 2. Spawn Robot URDF Description -->
  <!-- ========================================== -->
  <param name="robot_description" textfile="$(find mitacs)/ContinuO_URDF/urdf/ContinuO_lidar.urdf" />
  <node name="spawn_urdf" pkg="gazebo_ros" type="spawn_model" 
        args="-param robot_description -urdf -model ContinuO -z 0.5" output="screen" />

  <!-- ========================================== -->
  <!-- 3. State Publishers & TF -->
  <!-- ========================================== -->
  <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" output="screen" />
  <node name="odom_to_tf" pkg="mitacs" type="odom_to_tf.py" output="screen" />

  <!-- ========================================== -->
  <!-- 4. Load Controllers configuration & Spawn  -->
  <!-- ========================================== -->
  <rosparam file="$(find mitacs)/config/ros_control.yaml" command="load"/>
  
  <node name="controller_spawner" pkg="controller_manager" type="spawner" respawn="false"
        output="screen" ns="/ContinuO" 
        args="joint_state_controller 
              FL_HAA_position_controller 
              FL_HFE_position_controller 
              FL_KFE_position_controller 
              FR_HAA_position_controller 
              FR_HFE_position_controller 
              FR_KFE_position_controller 
              HL_HAA_position_controller 
              HL_EXTRA_position_controller 
              HL_HFE_position_controller 
              HL_KFE_position_controller 
              HR_HAA_position_controller 
              HR_EXTRA_position_controller 
              HR_HFE_position_controller 
              HR_KFE_position_controller"/>

  <!-- ========================================== -->
  <!-- 5. Optional Lidar Grid Extractor           -->
  <!-- ========================================== -->
  <node name="rl_grid_extractor" pkg="mitacs" type="rl_grid_extractor.py" output="screen" />

  <!-- ========================================== -->
  <!-- 6. Run RL ONNX Controller                 -->
  <!-- ========================================== -->
  <node name="rl_controller" pkg="mitacs" type="rl_controller.py" output="screen">
    <!-- Pass the absolute path to the local ONNX model on the host -->
    <param name="onnx_model_path" value="$(find mitacs)/Policy/Exported_policies/rough_fixed-slope-2.onnx"/>
  </node>
</launch>
